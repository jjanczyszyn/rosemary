---
const activities = [
  {
    title: 'Surf and Ocean',
    description: 'World-class surf breaks within about 15 minutes, depending on conditions. Kayaking, stand-up paddling, beach volleyball, and open-water swimming are part of daily life here.'
  },
  {
    title: 'Mountains and Jungle',
    description: 'Hiking trails lead from the property through Atlantic Forest to waterfalls, mountain summits, and ocean overlooks on the other side of the ridge. The trails begin at your door.'
  },
  {
    title: 'Digital Nomad Community',
    description: 'Florianópolis is widely regarded as one of Brazil\'s leading destinations for digital nomads and remote workers. Founders and builders from across the world choose it for the quality of life paired with reliable infrastructure.'
  },
  {
    title: 'Internationally Connected',
    description: 'Florianópolis International Airport (FLN) is roughly 40 minutes away. Direct flights connect to São Paulo (GRU) and onward to Europe, North America, and beyond.'
  },
  {
    title: 'Safe and Livable',
    description: 'Santa Catarina state is commonly cited among Brazil\'s more livable and lower-risk regions. We encourage all visitors to check current travel advisories as part of their personal due diligence. This is context, not a guarantee.'
  },
  {
    title: 'Southern Hemisphere Summer',
    description: 'When northern winters arrive, it is warm and bright here. December through March is peak season: warm water, long days, lush jungle, and the best surf conditions of the year.'
  },
  {
    title: 'Embodiment and Culture',
    description: 'The local community is active in yoga, breathwork, contact improvisation, and ecstatic dance. Ecstatic dance is hosted at the venue as part of the regular programming. You will hear Portuguese, English, Spanish, and more.'
  }
];
---

<section class="location" id="location">
  <div class="container">
    <h2 class="section-title text-center">Florianópolis: Nature, Culture, and Access</h2>
    <p class="lead text-center text-muted">
      An island known internationally as a hub for digital nomads, surfers, and people
      who want a different kind of life.
    </p>

    <div class="advantages-grid">
      {activities.map((item) => (
        <div class="advantage-card">
          <h3 class="advantage-title">{item.title}</h3>
          <p class="advantage-description">{item.description}</p>
        </div>
      ))}
    </div>

    <div class="location-map-placeholder">
      <p>Map: Rosemary Dream on the jungle hillside of Florianópolis, Brazil</p>
      <p class="text-muted" style="font-size: 0.85rem; margin-top: 0.5rem;">
        Coordinates: Approximately -27.6°, -48.5° (see the Investor Deck for exact location)
      </p>
    </div>
  </div>
</section>

<style>
  .location {
    background: var(--color-white);
  }

  .section-title {
    margin-bottom: 0.5rem;
  }

  .lead {
    max-width: 640px;
    margin: 0 auto var(--spacing-lg);
  }

  .advantages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-lg);
  }

  .advantage-card {
    padding: var(--spacing-md);
    border-left: 3px solid var(--color-accent);
    background: var(--color-bg);
  }

  .advantage-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .advantage-description {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0;
  }

  .location-map-placeholder {
    background: var(--color-bg);
    border: 2px dashed var(--color-border);
    border-radius: 8px;
    padding: var(--spacing-lg);
    text-align: center;
    color: var(--color-text-muted);
  }
</style>
