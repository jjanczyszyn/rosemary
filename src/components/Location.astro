---
/*
  GOOGLE MAPS EMBED NOTE
  ----------------------
  The provided link (https://maps.app.goo.gl/ujuCtjicLiBEo2Vv7) is a Google Maps
  short link. Short links redirect to the Google Maps app URL, which cannot be
  embedded in an iframe. Google Maps iframes require a specific
  https://www.google.com/maps/embed?pb=... URL format, which requires the
  raw coordinates or a Google Maps Embed API key.

  Decision: iframe embed removed. Fallback UI is the primary implementation:
  - Clickable satellite/aerial preview image (from the map directory)
  - Prominent "Open in Google Maps" button
  - Map images gallery below the preview

  This is the specified fallback behavior per the requirements.
*/

const baseUrl = import.meta.env.BASE_URL;

const MAPS_URL = 'https://maps.app.goo.gl/ujuCtjicLiBEo2Vv7';

// Map images from public/media/map/
// Files discovered: two satellite/aerial images of the property
const mapImages = [
  {
    file: 'map-overview.png',
    alt: 'Aerial satellite view of Rosemary Dream property location on the Florianópolis peninsula, with the Atlantic Ocean visible on both sides and the beach settlement to the left',
    label: 'Property location overview'
  },
  {
    file: 'map-detail.png',
    alt: 'Detailed satellite view showing the Rosemary Dream property boundary within Atlantic Forest jungle, with the ocean visible to the right',
    label: 'Property boundary detail'
  }
];

// First image is the aerial overview - best for the main preview
const previewImage = mapImages[0];

const activities = [
  {
    title: 'Ocean on Both Sides',
    description: 'The property sits on a peninsula where the Atlantic Ocean wraps around on multiple sides. Surf breaks, calm bays, and rocky coastlines are all within reach.'
  },
  {
    title: 'Jungle Trails to the Ocean',
    description: 'Hiking trails lead from the property directly through Atlantic Forest, down the hillside, and through to ocean access on the other side of the ridge.'
  },
  {
    title: 'Beach and Town Nearby',
    description: 'A beach settlement and local services are a short distance from the property. The island\'s main city center, international restaurants, and quality healthcare are accessible by car.'
  },
  {
    title: 'Internationally Connected',
    description: 'Florianópolis International Airport (FLN) is roughly 40 minutes away. Direct flights connect to São Paulo (GRU) and onward to Europe, North America, and beyond.'
  },
  {
    title: 'Digital Nomad Hub',
    description: 'Florianópolis is widely regarded as one of Brazil\'s leading destinations for digital nomads and remote workers. Founders and builders from across the world choose it for quality of life paired with reliable infrastructure.'
  },
  {
    title: 'Livable Region',
    description: 'Santa Catarina state is commonly cited among Brazil\'s more livable regions. We encourage all visitors to check current travel advisories as part of their personal due diligence. This is context, not a guarantee.'
  },
  {
    title: 'Southern Hemisphere Summer',
    description: 'When northern winters arrive, it is warm and bright here. December through March brings warm water, long days, lush jungle, and the best surf conditions of the year.'
  }
];
---

<section class="location" id="location">
  <div class="container">

    <!-- Section header -->
    <h2 class="section-title text-center">Location</h2>
    <p class="lead text-center text-muted">
      Find Rosemary Dream on the map and explore what surrounds it.
    </p>

    <div class="location-body text-center">
      <p>
        Rosemary Dream sits in the lush, ocean-kissed landscape of Florianópolis, Brazil.
        You are held by jungle, coastline, and the kind of outdoors that makes daily
        movement feel inevitable.
      </p>
    </div>

    <!-- Map preview and CTA -->
    <div class="map-section">

      <!-- Clickable aerial preview -->
      <a
        href={MAPS_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="map-preview-link"
        aria-label="Open Rosemary Dream on Google Maps in a new tab"
      >
        <div class="map-preview-wrapper">
          <img
            src={`${baseUrl}media/map/${previewImage.file}`}
            alt={previewImage.alt}
            class="map-preview-img"
            loading="lazy"
          />
          <div class="map-preview-overlay">
            <div class="map-preview-overlay-inner">
              <svg class="maps-icon" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" fill="currentColor"/>
              </svg>
              <span>View on Google Maps</span>
            </div>
          </div>
        </div>
      </a>

      <!-- CTA row -->
      <div class="map-cta-row">
        <a
          href={MAPS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
        >
          Open in Google Maps
        </a>
        <a
          href={MAPS_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="map-text-link"
        >
          View Rosemary Dream on Google Maps
        </a>
      </div>

      <p class="map-cta-note text-muted">
        Prefer to explore visually? Open the exact pin and zoom out to see beaches,
        trails, and the wider island.
      </p>
    </div>

    <!-- Map images gallery -->
    <div class="map-gallery-section">
      <h3 class="map-gallery-title">Aerial Views</h3>
      <p class="map-gallery-note text-muted">Click any image to open full size.</p>
      <div class="map-gallery">
        {mapImages.map((img) => (
          <a
            href={`${baseUrl}media/map/${img.file}`}
            target="_blank"
            rel="noopener noreferrer"
            class="map-thumb-link"
            aria-label={`View full size: ${img.label}`}
          >
            <div class="map-thumb-wrapper">
              <img
                src={`${baseUrl}media/map/${img.file}`}
                alt={img.alt}
                class="map-thumb-img"
                loading="lazy"
              />
              <div class="map-thumb-overlay">
                <span>{img.label}</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>

    <!-- Divider -->
    <hr class="section-divider" />

    <!-- Surrounding area bullets -->
    <h3 class="subsection-title text-center">Florianópolis: Nature, Culture, and Access</h3>
    <p class="sublead text-center text-muted">
      An island known internationally as a hub for digital nomads, surfers, and people
      who want a different kind of life.
    </p>

    <div class="advantages-grid">
      {activities.map((item) => (
        <div class="advantage-card">
          <h4 class="advantage-title">{item.title}</h4>
          <p class="advantage-description">{item.description}</p>
        </div>
      ))}
    </div>

  </div>
</section>

<style>
  .location {
    background: var(--color-white);
  }

  .section-title {
    margin-bottom: 0.5rem;
  }

  .lead {
    max-width: 640px;
    margin: 0 auto var(--spacing-sm);
  }

  .location-body {
    max-width: 640px;
    margin: 0 auto var(--spacing-lg);
  }

  .location-body p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
    margin: 0;
  }

  /* ---- Map section ---- */
  .map-section {
    margin-bottom: var(--spacing-lg);
  }

  .map-preview-link {
    display: block;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: var(--spacing-md);
    text-decoration: none;
  }

  .map-preview-wrapper {
    position: relative;
    width: 100%;
    max-height: 480px;
    overflow: hidden;
    background: var(--color-bg);
  }

  .map-preview-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    max-height: 480px;
    display: block;
    transition: transform 0.4s ease;
  }

  .map-preview-link:hover .map-preview-img {
    transform: scale(1.02);
  }

  .map-preview-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0);
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 1.5rem;
    transition: background 0.3s ease;
  }

  .map-preview-link:hover .map-preview-overlay {
    background: rgba(0, 0, 0, 0.15);
  }

  .map-preview-overlay-inner {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255, 255, 255, 0.95);
    color: var(--color-text);
    padding: 0.6rem 1rem;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 500;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  .maps-icon {
    width: 18px;
    height: 18px;
    color: #d94235;
    flex-shrink: 0;
  }

  .map-cta-row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: var(--spacing-sm);
  }

  .map-text-link {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-size: 0.95rem;
    transition: opacity var(--transition);
  }

  .map-text-link:hover {
    opacity: 0.75;
  }

  .map-cta-note {
    font-size: 0.9rem;
    margin: 0;
  }

  /* ---- Map gallery ---- */
  .map-gallery-section {
    margin-bottom: var(--spacing-lg);
  }

  .map-gallery-title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    margin-bottom: 0.25rem;
  }

  .map-gallery-note {
    font-size: 0.85rem;
    margin-bottom: var(--spacing-sm);
  }

  .map-gallery {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-sm);
  }

  .map-thumb-link {
    display: block;
    border-radius: 6px;
    overflow: hidden;
    text-decoration: none;
  }

  .map-thumb-wrapper {
    position: relative;
    overflow: hidden;
    background: var(--color-bg);
    aspect-ratio: 16 / 7;
  }

  .map-thumb-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.35s ease;
  }

  .map-thumb-link:hover .map-thumb-img {
    transform: scale(1.04);
  }

  .map-thumb-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0);
    display: flex;
    align-items: flex-end;
    padding: 0.75rem;
    transition: background 0.3s ease;
  }

  .map-thumb-link:hover .map-thumb-overlay {
    background: rgba(0,0,0,0.25);
  }

  .map-thumb-overlay span {
    font-size: 0.8rem;
    color: white;
    background: rgba(0,0,0,0.55);
    padding: 0.25rem 0.6rem;
    border-radius: 3px;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .map-thumb-link:hover .map-thumb-overlay span {
    opacity: 1;
  }

  /* ---- Divider ---- */
  .section-divider {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: var(--spacing-lg) 0;
  }

  .subsection-title {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .sublead {
    max-width: 560px;
    margin: 0 auto var(--spacing-lg);
  }

  /* ---- Activity bullets ---- */
  .advantages-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--spacing-md);
  }

  .advantage-card {
    padding: var(--spacing-md);
    border-left: 3px solid var(--color-accent);
    background: var(--color-bg);
  }

  .advantage-title {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .advantage-description {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0;
  }

  /* ---- Responsive ---- */
  @media (max-width: 600px) {
    .map-cta-row {
      flex-direction: column;
      align-items: flex-start;
    }

    .map-preview-wrapper {
      max-height: 300px;
    }

    .map-preview-img {
      max-height: 300px;
    }
  }
</style>
