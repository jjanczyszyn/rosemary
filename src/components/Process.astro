---
const baseUrl = import.meta.env.BASE_URL;

const steps = [
  {
    number: '01',
    title: 'Request the Investor Deck',
    description: 'Full documentation: property details, legal structure overview, investment mechanics, programming plans, and a due diligence checklist. Nothing is hidden.'
  },
  {
    number: '02',
    title: 'Review at Your Own Pace',
    description: 'Take the time you need. We answer questions by email or on a call. No pressure timeline, no artificial deadlines. If it is right, it will be clear.'
  },
  {
    number: '03',
    title: 'Schedule a Call or Visit',
    description: 'We can do a virtual walkthrough or you can visit the property in person. The jungle and the surf speak for themselves. We recommend seeing it before deciding.'
  },
  {
    number: '04',
    title: 'Engage Your Own Advisors',
    description: 'Consult your legal and financial advisors independently. We provide full transparency and welcome scrutiny. This is the step we insist you not skip.'
  },
  {
    number: '05',
    title: 'Join the Investor Circle',
    description: 'When you are ready and the structure fits, we formalize the commitment. Capacity is limited to maintain community quality. This is not artificial scarcity.'
  },
  {
    number: '06',
    title: 'Build the Village',
    description: 'The first village season runs December through February. Come be part of it. Work on something real. Surf every morning. Belong to something you helped build.'
  }
];
---

<section class="process" id="process">
  <div class="container">
    <h2 class="section-title text-center">Your Next Step</h2>
    <p class="lead text-center text-muted">
      Simple, transparent, no obligation at any stage.
    </p>

    <div class="steps-grid">
      {steps.map((step) => (
        <div class="step-card">
          <span class="step-number">{step.number}</span>
          <h3 class="step-title">{step.title}</h3>
          <p class="step-description">{step.description}</p>
        </div>
      ))}
    </div>

    <div class="process-cta text-center">
      <p class="process-cta-text">Ready to start the conversation?</p>
      <div class="process-cta-buttons">
        <a href="https://docs.google.com/document/d/1aaB4tGA4yIxTO7PtIJrOrrPHNhBcXPG3X2FilwcLgvk/edit?usp=sharing" class="btn btn-primary btn-large" target="_blank" rel="noopener">
          View the Info Packet
        </a>
        <a href="#contact" class="btn btn-secondary btn-large">
          Request the Investor Deck
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .process {
    background: var(--color-white);
  }

  .section-title {
    margin-bottom: 0.5rem;
  }

  .lead {
    margin-bottom: var(--spacing-lg);
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
  }

  .step-card {
    position: relative;
    padding: var(--spacing-md);
    padding-top: calc(var(--spacing-md) + 1rem);
    background: var(--color-bg);
    border-radius: 8px;
  }

  .step-number {
    position: absolute;
    top: -0.5rem;
    left: var(--spacing-md);
    font-family: var(--font-serif);
    font-size: 2rem;
    color: var(--color-accent);
    opacity: 0.3;
    font-weight: 500;
  }

  .step-title {
    font-family: var(--font-serif);
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .step-description {
    color: var(--color-text-muted);
    font-size: 0.95rem;
    margin: 0;
  }

  .process-cta {
    background: var(--color-accent-light);
    padding: var(--spacing-lg);
    border-radius: 8px;
  }

  .process-cta-text {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    margin-bottom: var(--spacing-md);
  }

  .process-cta-buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  @media (max-width: 768px) {
    .process-cta-buttons {
      flex-direction: column;
      align-items: center;
    }

    .process-cta-buttons .btn {
      width: 100%;
      max-width: 300px;
    }
  }
</style>
