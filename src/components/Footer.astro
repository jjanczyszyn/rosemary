---
const currentYear = new Date().getFullYear();

const contactEmail = 'hello@justinalydia.com';
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-main">
        <p class="footer-brand">Rosemary Dream</p>
        <p class="footer-tagline">Co-invest in a jungle village above the surf.</p>
        <p class="footer-location">Florianópolis, Brazil</p>
      </div>

      <div class="footer-contact">
        <p class="footer-label">Contact</p>
        <a href={`mailto:${contactEmail}`}>{contactEmail}</a>
        <p class="footer-site"><a href="https://justinalydia.com" target="_blank" rel="noopener">justinalydia.com</a></p>
      </div>

      <div class="footer-links">
        <p class="footer-label">Quick Links</p>
        <ul>
          <li><a href="#about">About</a></li>
          <li><a href="#village">Village Season</a></li>
          <li><a href="#investment">Programming</a></li>
          <li><a href="#faq">FAQ</a></li>
          <li><a href="#contact">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-disclaimer">
      <p>
        <strong>Disclaimer:</strong> Images and videos may include adjacent areas not included
        in the property boundary. No rights or access to depicted areas are implied unless
        explicitly stated in legal documentation. Statements about location, lifestyle, and
        investment potential are for informational purposes only and do not constitute
        guarantees, promises, or legal or financial advice. Nothing on this website is a
        solicitation to invest or an offer of securities. All buyers and investors should
        conduct independent due diligence and consult with qualified professionals before
        making any decision. See the Investor Deck for complete details.
        Not investment advice. Details subject to legal documentation and local regulations.
      </p>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Rosemary Dream. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-text);
    color: white;
    padding: var(--spacing-xl) 0 var(--spacing-md);
  }

  .footer-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-lg);
    padding-bottom: var(--spacing-lg);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-brand {
    font-family: var(--font-serif);
    font-size: 1.5rem;
    margin-bottom: 0.5rem;
  }

  .footer-tagline {
    font-style: italic;
    opacity: 0.7;
    font-size: 0.9rem;
    margin-bottom: 0.5rem;
  }

  .footer-location {
    opacity: 0.7;
    font-size: 0.9rem;
  }

  .footer-label {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.5;
    margin-bottom: 0.75rem;
  }

  .footer-contact a {
    color: white;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-contact a:hover {
    opacity: 0.8;
  }

  .footer-site {
    margin-top: 0.5rem;
  }

  .footer-site a {
    font-size: 0.9rem;
    opacity: 0.7;
  }

  .footer-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.5rem;
  }

  .footer-links a {
    color: white;
    opacity: 0.7;
    text-decoration: none;
    transition: opacity var(--transition);
  }

  .footer-links a:hover {
    opacity: 1;
  }

  .footer-disclaimer {
    padding: var(--spacing-md) 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-disclaimer p {
    font-size: 0.8rem;
    opacity: 0.6;
    line-height: 1.6;
    margin: 0;
  }

  .footer-disclaimer strong {
    opacity: 1;
  }

  .footer-bottom {
    padding-top: var(--spacing-md);
    text-align: center;
  }

  .footer-bottom p {
    font-size: 0.85rem;
    opacity: 0.5;
    margin: 0;
  }
</style>
